---
import { getEssayPath, getVisibleEssayRouteEntries } from '../../lib/content';
import { createWithBase } from '../../utils/format';

export const prerender = true;

export async function getStaticPaths() {
  const routeEntries = await getVisibleEssayRouteEntries();
  return routeEntries.map(({ slug }) => ({
    params: { slug },
    props: { slug }
  }));
}

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);

return Astro.redirect(withBase(getEssayPath(Astro.props.slug)), 301);
---
