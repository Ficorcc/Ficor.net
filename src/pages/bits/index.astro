---
import BitsPageView from '../../components/BitsPageView.astro';
import { getBitsPageData } from '../../lib/bits';
import { PAGE_SIZE_BITS } from '../../../site.config.mjs';

const currentPage = 1;
const { items, yearOptions, totalCount, totalPages } = await getBitsPageData(currentPage, PAGE_SIZE_BITS);
---

<BitsPageView
  items={items}
  resultCount={totalCount}
  currentPage={currentPage}
  totalPages={totalPages}
  yearOptions={yearOptions}
/>
