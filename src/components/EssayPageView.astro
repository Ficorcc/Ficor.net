---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagFilterHeader from './TagFilterHeader.astro';
import EssayCard from './EssayCard.astro';
import Pagination from './Pagination.astro';
import { createWithBase, getEssayDerivedText, getEssayPath, getEssaySlug, type EssayEntry } from '../lib/content';
import { getThemeSettings, getVisibleArticleMetaTags } from '../lib/theme-settings';
import { joinPageSubtitleText } from '../utils/format';

const {
  currentPage,
  items,
  resultCount,
  totalPages
} = Astro.props as {
  currentPage: number;
  items: EssayEntry[];
  resultCount: number;
  totalPages: number;
};

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const {
  settings: {
    page,
    ui: { articleMeta }
  }
} = getThemeSettings();

const pageTitleText = page.essay.title || '随笔';
const pageTitleParts = [pageTitleText, currentPage > 1 ? `第 ${currentPage} 页` : null].filter(Boolean);
const pageTitle = pageTitleParts.join(' · ');
const subtitleText = joinPageSubtitleText(
  page.essay.subtitle,
  `共 ${resultCount} 篇`,
  totalPages > 1 ? `第 ${currentPage} / ${totalPages} 页` : null
);
const pageDescription = joinPageSubtitleText(
  `${pageTitleText}列表`,
  page.essay.subtitle,
  `共 ${resultCount} 篇`,
  totalPages > 1 ? `第 ${currentPage} / ${totalPages} 页` : null
) ?? `${pageTitleText}列表`;
const fallbackListId = 'essay-tag-list';
---

<BaseLayout title={pageTitle} description={pageDescription} bodyClass="essay-page">
  <div
    class="entry-filters"
    data-entry-filters
    data-index-url="/essay/index.json"
  >
    <TagFilterHeader
      pageTitleText={pageTitleText}
      subtitleText={subtitleText}
      rssHref={withBase('/essay/rss.xml')}
      pickerHref={`#${fallbackListId}`}
      fallbackListId={fallbackListId}
      dialogTitleId="essay-tag-dialog-title"
      searchAriaLabel={`搜索${pageTitleText}`}
      headerClass="page-header page-header--essay page-header--with-search"
    />
  </div>

  <div class="list">
    {items.map((entry) => (
      <EssayCard
        href={withBase(getEssayPath(entry))}
        slug={getEssaySlug(entry)}
        title={entry.data.title}
        excerpt={getEssayDerivedText(entry).excerpt}
        date={entry.data.date}
        visibleTags={getVisibleArticleMetaTags(entry.data.tags, 'list')}
        articleMetaSettings={articleMeta}
        badge={entry.data.badge ?? entry.data.category}
      />
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    firstPath="/essay/"
    getPagePath={(pageNumber: number) => `/essay/page/${pageNumber}/`}
    label={`${pageTitleText}分页`}
  />

  <script>
    import '../scripts/entry-search.ts';
  </script>
</BaseLayout>
